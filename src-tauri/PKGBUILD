# Maintainer: Leo-Codex

pkgname=minimalnotes
pkgver=0.1.0
pkgrel=1
pkgdesc="Editor de texto plano ultra-ligero"
arch=('x86_64')
url="https://github.com/Leo-Codex/NOTES"
license=('MIT')
depends=('webkit2gtk-4.1' 'gtk3' 'glibc')
makedepends=('nodejs' 'npm' 'rust' 'cargo' 'base-devel')
source=("${pkgname}-${pkgver}.tar.gz::${url}/archive/v${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
  cd "${srcdir}/${pkgname}-${pkgver}"
  npm ci
  npm run tauri build
}

package() {
  cd "${srcdir}/${pkgname}-${pkgver}"

  install -Dm755 "src-tauri/target/release/${pkgname}" \
    "${pkgdir}/usr/bin/${pkgname}"

  install -Dm644 "src-tauri/icons/icon.png" \
    "${pkgdir}/usr/share/pixmaps/${pkgname}.png"

  install -Dm644 /dev/stdin \
    "${pkgdir}/usr/share/applications/${pkgname}.desktop" <<EOF
[Desktop Entry]
Type=Application
Name=MinimalNotes
Comment=${pkgdesc}
Exec=${pkgname}
Icon=${pkgname}
Categories=Utility;TextEditor;
Terminal=false
EOF
}
