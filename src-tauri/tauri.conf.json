{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "identifier": "com.minimalnotes.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MinimalNotes",
        "width": 1100,
        "height": 720,
        "minWidth": 320,
        "minHeight": 240,
        "resizable": true,
        "decorations": true,
        "center": true,
        "backgroundColor": "#F6F5F0"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
